---
import BaseLayout from "../layouts/BaseLayout.astro";
import ShouldILoop from "../components/ShouldILoop.astro";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "How do I know if my AI task needs a loop?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Use a loop when the AI needs to try something, check what happened, and use that result to decide the next move. Use one prompt for one clear answer. Use fixed steps when the order is already known.",
      },
    },
    {
      "@type": "Question",
      name: "What's the difference between a loop, fixed steps, and a prompt?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "A prompt is one instruction and one answer. Fixed steps are a known list of actions. A loop means the AI tries, checks the result, and tries again until the goal is reached.",
      },
    },
  ],
};
---
<BaseLayout
  title="Should I Loop?"
  description="Describe an AI task and get a plain-English answer: one prompt, fixed steps, or a loop."
  jsonLd={jsonLd}
>
  <section class="container page-hero">
    <p class="kicker">the tool</p>
    <h1>Should I loop?</h1>
    <p class="lead" style="margin-bottom:1.9rem;">
      Describe the task in normal words. The tool tells you whether to use one prompt, fixed steps,
      or a loop where the AI checks its work and tries again.
    </p>
    <ShouldILoop />
  </section>

  <section class="container section">
    <h2>How the answer works</h2>
    <div class="grid grid-2 prose">
      <div>
        <p><strong>One prompt.</strong> One clear instruction with one answer, like translate, summarize, or format. The AI does not need to check anything after it answers.</p>
        <p><strong>Fixed steps.</strong> Several steps, but the order is already known. This is simpler than a loop.</p>
      </div>
      <div>
        <p><strong>Loop.</strong> The AI tries something, checks what happened, and uses that result to choose the next move.</p>
        <p><strong>Need more detail.</strong> The task is unclear. Start simple, then add a loop only if the AI needs to react to results.</p>
      </div>
    </div>
  </section>
</BaseLayout>
