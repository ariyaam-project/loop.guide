---
import BaseLayout from "../layouts/BaseLayout.astro";
import ShouldILoop from "../components/ShouldILoop.astro";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "How do I know if my AI task needs a loop?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Use a loop when the agent has feedback to react to. That covers running and verifying its own output, multi-step work with dependencies, or iterating until a condition is met. Use a single prompt for one deterministic transform, and a fixed chain for ordered steps with nothing to react to.",
      },
    },
    {
      "@type": "Question",
      name: "What's the difference between a loop, a chain, and a prompt?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "A prompt is one shot in, one answer out. A chain runs fixed steps A→B→C. A loop is dynamic: act, observe the result, reason, and repeat until done.",
      },
    },
  ],
};
---
<BaseLayout
  title="Should I Loop?"
  description="Describe your AI task. Get a verdict (loop, single prompt, or chain) with the reasoning and the recommended pattern."
  jsonLd={jsonLd}
>
  <section class="container page-hero">
    <p class="kicker">the tool</p>
    <h1>Should I loop?</h1>
    <p class="lead" style="margin-bottom:1.9rem;">
      Describe the task the way you would say it out loud. You get a verdict, loop, single prompt, or chain,
      with the reasoning and the pattern to build it.
    </p>
    <ShouldILoop />
  </section>

  <section class="container section">
    <h2>How the verdict works</h2>
    <div class="grid grid-2 prose">
      <div>
        <p><strong>Single prompt.</strong> One deterministic transform with a single answer, like translate, summarize, or format. Nothing to react to.</p>
        <p><strong>Chain.</strong> Several steps, but fixed and ordered, with nothing surprising between them. Predictable, and simpler than a loop.</p>
      </div>
      <div>
        <p><strong>Loop.</strong> The agent acts, observes a real result (tests, errors, data), reasons, and repeats until done. Use it when there is genuine feedback or iteration.</p>
        <p><strong>Borderline.</strong> Signals are mixed. Start with the simplest option, and add a loop only if a single shot keeps falling short.</p>
      </div>
    </div>
  </section>
</BaseLayout>
