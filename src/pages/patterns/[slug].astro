---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PatternFlowDiagram from "../../components/PatternFlowDiagram.astro";
import { PATTERNS, getPattern, type PatternSlug } from "../../lib/patterns";

export function getStaticPaths() {
  return PATTERNS.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const p = getPattern(slug as PatternSlug);
const patternIndex = PATTERNS.findIndex((pattern) => pattern.slug === p.slug);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: p.name,
  description: p.tagline,
  step: p.anatomy.map((s, i) => ({ "@type": "HowToStep", position: i + 1, name: s })),
};
---
<BaseLayout title={p.name} description={p.tagline} jsonLd={jsonLd}>
  <article class="container pattern-detail">
    <p class="pattern-back"><a href="/patterns">← All patterns</a></p>
    <div class="pattern-detail-hero">
      <div>
        <h1>{p.name}</h1>
        <p class="lead">{p.tagline}</p>
        <p>
          <span class="tag">{p.cost} cost</span>
          <span class="tag">{p.risk} risk</span>
        </p>
      </div>
      <PatternFlowDiagram pattern={p} index={patternIndex} variant="full" />
    </div>

    <div class="prose narrow">
      <h2>When to use it</h2>
      <ul>{p.whenToUse.map((x) => <li>{x}</li>)}</ul>

      <h2>When not to use it</h2>
      <ul>{p.whenNotToUse.map((x) => <li>{x}</li>)}</ul>

      <h2>How it works</h2>
      <pre><code>{p.anatomy.join("  then  ")}</code></pre>

      <h2>Things to watch</h2>
      <ul>{p.watchOuts.map((x) => <li>{x}</li>)}</ul>

      <h2>How to start</h2>
      <ul>{p.starter.map((x) => <li>{x}</li>)}</ul>

      <div class="card" style="margin-top:2rem;background:var(--bg-soft);">
        <strong>Not sure this is the right loop?</strong>
        <p class="dim" style="margin:0.4rem 0 0.8rem;">Describe your task and get a plain-English recommendation.</p>
        <a class="btn btn-primary" href="/should-i-loop">Try “Should I Loop?”</a>
      </div>
    </div>
  </article>
</BaseLayout>
