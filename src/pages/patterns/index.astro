---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PatternFlowDiagram from "../../components/PatternFlowDiagram.astro";
import { PATTERNS } from "../../lib/patterns";
---
<BaseLayout
  title="Loop Patterns"
  description="Seven common AI loop setups, explained in plain language."
>
  <section class="container page-hero">
    <span class="eyebrow">the guide</span>
    <h1>Loop patterns</h1>
    <p class="lead">These are common ways to set up an AI that checks its work. Start with the smallest one that fits your task.</p>
    <div class="grid grid-2 pattern-card-grid">
      {PATTERNS.map((p, index) => (
        <a class="card pattern-card" href={`/patterns/${p.slug}`}>
          <PatternFlowDiagram pattern={p} index={index} variant="card" />
          <div class="pattern-card-body">
            <div style="display:flex;justify-content:space-between;gap:0.5rem;align-items:center;">
            <strong>{p.name}</strong>
            <span>
              <span class="tag">{p.cost} cost</span>
              <span class="tag">{p.risk} risk</span>
            </span>
            </div>
            <p class="dim" style="margin:0.6rem 0 0;">{p.tagline}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
