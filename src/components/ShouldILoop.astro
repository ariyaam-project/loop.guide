---
// Self-contained "Should I Loop?" island. Posts to /api/should-i-loop,
// gracefully degrades if the endpoint is unreachable (e.g. pure static preview).
interface Props { compact?: boolean }
const { compact = false } = Astro.props;
const id = "sil-" + Math.random().toString(36).slice(2, 8);
---
<div class="sil" data-sil={id}>
  <div class={compact ? "sil-shell sil-shell-compact" : "sil-shell"}>
    <div class={compact ? "sil-layout sil-layout-compact" : "sil-layout"}>
      <div class="sil-input">
        <label for={`${id}-task`} class="sil-label">
          What should the AI do?
        </label>
        <textarea id={`${id}-task`} class="task" data-task
          placeholder="Example: Check every new support message, draft a reply, and keep improving it until it answers the customer."></textarea>

        <div class="examples" data-examples>
          <span class="examples-label">Try:</span>
          <button type="button" class="chip" data-ex="Rewrite this email in a friendlier tone.">One prompt</button>
          <button type="button" class="chip" data-ex="Read this form, write a summary, then send it to the right team.">Fixed steps</button>
          <button type="button" class="chip" data-ex="Check every new support message, draft a reply, and keep revising until the reply answers the customer.">Loop</button>
        </div>

        <div class="prompt-history hidden" data-history-wrap>
          <div class="prompt-history-head">
            <span>Recent prompts</span>
            <button type="button" class="history-clear" data-history-clear>Clear</button>
          </div>
          <div class="history-list" data-history-list></div>
        </div>

        <div class="sil-actions">
          <button type="button" class="btn btn-primary" data-analyze>Analyze</button>
          <button type="button" class="btn" data-clear>Clear</button>
        </div>
      </div>

      <div class="sil-result" data-result aria-live="polite">
        <p class="result-empty-title">Your answer will appear here.</p>
        <p class="dim result-empty-copy">Describe the job, then click <strong>Analyze</strong>. The tool will choose one prompt, fixed steps, or a loop.</p>
      </div>
    </div>
  </div>
  {!compact && (
    <p class="dim sil-footnote">
      The tool gives a simple recommendation. Your text is not stored.
    </p>
  )}
</div>

<script>
  type Verdict = "loop" | "single" | "chain" | "borderline";
  const LABEL: Record<Verdict, string> = { loop: "Use a loop", single: "Use one prompt", chain: "Use fixed steps", borderline: "Need more detail" };
  const CLS: Record<Verdict, string> = { loop: "v-loop", single: "v-single", chain: "v-chain", borderline: "v-borderline" };
  const ANSWER: Record<Verdict, string> = {
    loop: "Let the AI try, check what happened, and try again if needed.",
    single: "Use one clear instruction. The AI should not need to check anything after it answers.",
    chain: "Use a short list of fixed steps. The order is already known.",
    borderline: "I need a little more detail to be sure. Start simple, then add a loop only if the AI needs to react to results.",
  };
  const PATTERN_COPY: Record<string, { name: string; text: string; steps: string[] }> = {
    retry: {
      name: "Retry",
      text: "Good when the AI can check if the answer worked, then try again.",
      steps: ["Decide what counts as done.", "Let the AI try once.", "Check the result.", "If it fails, try a different fix."],
    },
    "plan-execute-verify": {
      name: "Plan and check",
      text: "Good when the job has several steps and each step should be checked.",
      steps: ["Write the steps.", "Do one step.", "Check it.", "Move to the next step."],
    },
    "explore-narrow": {
      name: "Try a few options",
      text: "Good when you do not know the best path yet.",
      steps: ["Try a few small options.", "Compare the results.", "Keep the best option.", "Stop when one is good enough."],
    },
    "human-in-the-loop": {
      name: "Ask a person",
      text: "Good when a person should approve an important or risky choice.",
      steps: ["List what needs approval.", "Let the AI prepare the work.", "Ask a person before the risky step.", "Continue after approval."],
    },
    verification: {
      name: "Add a checker",
      text: "Good when quality matters and the AI needs a second check.",
      steps: ["Say what a good answer looks like.", "Let the AI make the answer.", "Check it against that rule.", "Send it back if it is not good enough."],
    },
    "event-driven": {
      name: "Run when something happens",
      text: "Good when the task should start after a new event, like a form, issue, or schedule.",
      steps: ["Choose what starts the task.", "Let the AI do the work.", "Save or send the result.", "Wait for the next event."],
    },
    "hill-climbing": {
      name: "Improve over time",
      text: "Good when the system should learn from past runs and get better.",
      steps: ["Save what happened each time.", "Look for what went wrong.", "Improve the instructions.", "Measure if it got better."],
    },
  };

  function esc(s: string) {
    return s.replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c]!));
  }

  function trackClarityEvent(name: string) {
    const clarity = (window as any).clarity;
    if (typeof clarity === "function") clarity("event", name);
  }

  document.querySelectorAll<HTMLElement>(".sil").forEach((root) => {
    const taskEl = root.querySelector<HTMLTextAreaElement>("[data-task]")!;
    const resultEl = root.querySelector<HTMLElement>("[data-result]")!;
    const analyzeBtn = root.querySelector<HTMLButtonElement>("[data-analyze]")!;
    const clearBtn = root.querySelector<HTMLButtonElement>("[data-clear]")!;
    const historyWrap = root.querySelector<HTMLElement>("[data-history-wrap]");
    const historyList = root.querySelector<HTMLElement>("[data-history-list]");
    const historyClearBtn = root.querySelector<HTMLButtonElement>("[data-history-clear]");
    const historyKey = "loops.guide.should-i-loop.history";
    let promptEntryTracked = false;

    function trackPromptEntry() {
      if (promptEntryTracked || !taskEl.value.trim()) return;

      promptEntryTracked = true;
      trackClarityEvent("should_i_loop_prompt_entered");
    }

    root.querySelectorAll<HTMLButtonElement>("[data-ex]").forEach((chip) => {
      chip.addEventListener("click", () => {
        taskEl.value = chip.dataset.ex || "";
        taskEl.focus();
        trackPromptEntry();
      });
    });

    clearBtn.addEventListener("click", () => {
      taskEl.value = "";
      promptEntryTracked = false;
      resultEl.innerHTML = '<p class="result-empty-title">Cleared.</p><p class="dim result-empty-copy">Describe the job, then click <strong>Analyze</strong>.</p>';
    });

    function readHistory(): string[] {
      try {
        const parsed = JSON.parse(localStorage.getItem(historyKey) || "[]");
        if (!Array.isArray(parsed)) return [];
        return parsed
          .filter((item): item is string => typeof item === "string")
          .map((item) => item.trim())
          .filter((item) => item.length > 0 && item.length <= 4000)
          .slice(0, 6);
      } catch {
        return [];
      }
    }

    function writeHistory(items: string[]) {
      try {
        localStorage.setItem(historyKey, JSON.stringify(items.slice(0, 6)));
      } catch {
        // Ignore storage failures, such as private browsing quota limits.
      }
    }

    function renderHistory() {
      if (!historyWrap || !historyList) return;

      const items = readHistory();
      historyList.replaceChildren();
      historyWrap.classList.toggle("hidden", items.length === 0);

      items.forEach((item) => {
        const button = document.createElement("button");
        button.type = "button";
        button.className = "history-item";
        button.textContent = item;
        button.title = item;
        button.addEventListener("click", () => {
          taskEl.value = item;
          taskEl.focus();
          trackPromptEntry();
        });
        historyList.append(button);
      });
    }

    function saveHistory(task: string) {
      const cleanTask = task.trim();
      if (!cleanTask) return;

      const next = [cleanTask, ...readHistory().filter((item) => item !== cleanTask)].slice(0, 6);
      writeHistory(next);
      renderHistory();
    }

    historyClearBtn?.addEventListener("click", () => {
      try {
        localStorage.removeItem(historyKey);
      } catch {
        writeHistory([]);
      }
      renderHistory();
    });

    renderHistory();
    taskEl.addEventListener("input", trackPromptEntry);

    function certainty(score: number) {
      if (score >= 80) return "Very sure";
      if (score >= 60) return "Fairly sure";
      return "Low certainty";
    }

    function simpleReasons(d: any, v: Verdict) {
      const blocked = /\b(patternslug|pre-analysis|heuristic|signals?|deterministic|non-iterative|iterative process|llm|confidence|discrepancy|nuanced|classification|verdict|architecture|runtime|validator|orchestration|mcp)\b/i;
      const fallback: Record<Verdict, string[]> = {
        loop: ["The AI needs to use the result of one try before choosing the next move."],
        single: ["This looks like one clear job with one answer."],
        chain: ["The steps are already known and can be done in order."],
        borderline: ["There is not enough clear detail to choose confidently yet."],
      };
      const cleaned = (d.reasons || [])
        .filter((r: unknown): r is string => typeof r === "string")
        .map((r: string) =>
          r
            .replace(/\bruntime feedback\b/gi, "feedback from the result")
            .replace(/\bsingle prompt\b/gi, "one prompt")
            .replace(/\bAI automation task\b/gi, "task for an AI")
            .trim(),
        )
        .filter((r: string) => r.length >= 8 && r.length <= 150)
        .filter((r: string) => !blocked.test(r))
        .filter((r: string) => !/^\s*[-*]?\s*[a-zA-Z]+Slug\s*:/i.test(r))
        .slice(0, 3);
      return cleaned.length ? cleaned : fallback[v];
    }

    async function analyze() {
      const task = taskEl.value.trim();
      if (!task) { resultEl.innerHTML = '<p class="result-empty-title">Type a task first.</p><p class="dim result-empty-copy">A sentence or two is enough.</p>'; return; }
      saveHistory(task);
      resultEl.innerHTML = '<p class="skeleton">Analyzing…</p>';
      try {
        const res = await fetch("/api/should-i-loop", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ task }),
        });
        const data = await res.json();
        if (res.status === 422 || data.verdict === "rejected") {
          const reason = data.reasons?.[0] ?? "That does not look like an AI automation task.";
          resultEl.innerHTML = `
            <div class="result-summary">
              <span class="verdict-badge v-borderline">Not enough</span>
            </div>
            <h3 class="result-heading">Try another task</h3>
            <p class="result-answer">${esc(reason)}</p>
            <p class="dim result-empty-copy">Describe work you want an AI to do, like fixing tests, watching new messages, or processing documents.</p>
          `;
          trackClarityEvent("should_i_loop_response_received");
          return;
        }
        if (!res.ok) throw new Error("bad status");
        render(data);
        trackClarityEvent("should_i_loop_response_received");
      } catch {
        resultEl.innerHTML =
          '<p class="dim">Couldn\'t reach the analyzer endpoint (this happens on a pure static preview). ' +
          'Run <code>npm run dev</code> or deploy to Cloudflare and it works.</p>';
      }
    }

    function render(d: any) {
      const v = (d.verdict as Verdict) || "borderline";
      const reasons = simpleReasons(d, v).map((r: string) => `<li>${esc(r)}</li>`).join("");
      const pattern = PATTERN_COPY[d.pattern?.slug] || {
        name: d.pattern?.name || "Recommended setup",
        text: d.pattern?.tagline || "Use this setup for the task.",
        steps: d.checklist || [],
      };
      const patternHref = d.pattern?.href || (d.pattern?.slug ? `/patterns/${d.pattern.slug}` : "/patterns");
      const checklist = pattern.steps.map((c: string) => `<li>${esc(c)}</li>`).join("");
      resultEl.innerHTML = `
        <div class="result-summary">
          <span class="verdict-badge ${CLS[v]}">${LABEL[v]}</span>
          <span class="result-certainty">${certainty(Number(d.confidence) || 0)}</span>
        </div>
        <h3 class="result-heading">Answer</h3>
        <p class="result-answer result-answer-main">${esc(ANSWER[v])}</p>
        <h3 class="result-heading">Why</h3>
        <ul class="reasons">${reasons}</ul>
        <div class="result-setup">
          <h3 class="result-heading">Best setup</h3>
          <p class="result-answer"><a href="${patternHref}"><strong>${esc(pattern.name)}</strong></a>: ${esc(pattern.text)}</p>
        </div>
        <details class="result-start">
          <summary class="dim result-details">Starter steps</summary>
          <ol class="reasons simple-steps">${checklist}</ol>
        </details>
        <button type="button" class="btn result-copy" data-copy>Copy</button>
      `;
      const copyBtn = resultEl.querySelector<HTMLButtonElement>("[data-copy]");
      copyBtn?.addEventListener("click", () => {
        const text = `Should I Loop? ${LABEL[v]}\nSimple answer: ${ANSWER[v]}\nWhy: ${simpleReasons(d, v).join(" ")}\nSuggested setup: ${pattern.name}. ${pattern.text}\nvia loops.guide`;
        navigator.clipboard?.writeText(text);
        copyBtn.textContent = "Copied ✓";
        setTimeout(() => (copyBtn.textContent = "Copy"), 1500);
      });
    }

    analyzeBtn.addEventListener("click", analyze);
    taskEl.addEventListener("keydown", (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === "Enter") analyze();
    });
  });
</script>
