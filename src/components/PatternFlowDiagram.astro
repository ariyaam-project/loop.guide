---
import type { Pattern } from "../lib/patterns";

interface Props {
  pattern: Pattern;
  index?: number;
  variant?: "full" | "card" | "mini";
}

const { pattern, index = 0, variant = "full" } = Astro.props;
const scope = `pf-${variant}-${pattern.slug}-${index}`;
const showHeading = variant === "full";
const viewBox = showHeading ? "0 0 1000 520" : "80 95 850 390";
const indexLabel = String(index + 1).padStart(2, "0");
const shortName = pattern.name
  .replace(" Loop", "")
  .replace(" / Evaluator", "")
  .replace("Plan → Execute → Verify", "Plan Verify")
  .replace("Explore → Narrow", "Explore Narrow")
  .replace("Human-in-the-Loop", "Human Gate");

const marker = {
  muted: `${scope}-muted`,
  loop: `${scope}-loop`,
  yes: `${scope}-yes`,
  no: `${scope}-no`,
};

const markerUrl = {
  muted: `url(#${marker.muted})`,
  loop: `url(#${marker.loop})`,
  yes: `url(#${marker.yes})`,
  no: `url(#${marker.no})`,
};

const cls = `pattern-flow pattern-flow-${variant} pattern-flow-${pattern.slug}`;
---

<div class={cls}>
  <svg
    class="pattern-flow-svg"
    viewBox={viewBox}
    role="img"
    aria-label={`${pattern.name}: ${pattern.tagline}`}
  >
    <defs>
      <marker id={marker.muted} viewBox="0 0 10 10" refX="8" refY="5" markerWidth="8" markerHeight="8" orient="auto">
        <path d="M 0 1 L 10 5 L 0 9 z" fill="var(--text-faint, #89919a)" />
      </marker>
      <marker id={marker.loop} viewBox="0 0 10 10" refX="8" refY="5" markerWidth="8" markerHeight="8" orient="auto">
        <path d="M 0 1 L 10 5 L 0 9 z" fill="var(--accent, #2457d6)" />
      </marker>
      <marker id={marker.yes} viewBox="0 0 10 10" refX="8" refY="5" markerWidth="8" markerHeight="8" orient="auto">
        <path d="M 0 1 L 10 5 L 0 9 z" fill="var(--green, #0f7d5d)" />
      </marker>
      <marker id={marker.no} viewBox="0 0 10 10" refX="8" refY="5" markerWidth="8" markerHeight="8" orient="auto">
        <path d="M 0 1 L 10 5 L 0 9 z" fill="var(--red, #bf3f37)" />
      </marker>
    </defs>

    {showHeading && (
      <>
        <text class="pf-index" x="60" y="70" text-anchor="start">{indexLabel}</text>
        <text class="pf-heading" x="60" y="110" text-anchor="start">{shortName}</text>
      </>
    )}

    {pattern.slug === "retry" && (
      <>
        <g class="pf-lines" stroke-width="2" fill="none">
          <path class="pf-track" d="M 200 300 L 290 300" marker-end={markerUrl.muted} />
          <path class="pf-pulse muted" d="M 200 300 L 285 300" />
          <path class="pf-track" d="M 440 300 L 530 300" marker-end={markerUrl.muted} />
          <path class="pf-pulse muted" d="M 440 300 L 525 300" />
          <path class="pf-track yes" d="M 670 300 L 760 300" marker-end={markerUrl.yes} />
          <path class="pf-pulse yes" d="M 670 300 L 755 300" />
          <path class="pf-track loop" d="M 600 245 C 600 120, 370 120, 370 250" marker-end={markerUrl.loop} />
          <path class="pf-pulse loop" d="M 600 245 C 600 120, 370 120, 370 245" />
        </g>
        <text class="pf-label yes" x="715" y="290" text-anchor="middle">pass</text>
        <text class="pf-label loop" x="485" y="135" text-anchor="middle">fail: retry</text>

        <g class="pf-node start-node" transform="translate(160, 300)">
          <circle cx="0" cy="0" r="20" />
        </g>
        <text class="pf-note" x="160" y="340" text-anchor="middle">Start</text>

        <g class="pf-node model-node" transform="translate(300, 260)">
          <rect x="0" y="0" width="140" height="80" rx="10" />
          <text class="pf-node-title" x="70" y="45" text-anchor="middle">Model</text>
        </g>
        <text class="pf-note" x="370" y="360" text-anchor="middle">generate draft</text>

        <g class="pf-node decision-node" transform="translate(600, 300)">
          <polygon points="0,-50 70,0 0,50 -70,0" />
          <text class="pf-node-title" x="0" y="-5" text-anchor="middle">check</text>
          <text class="pf-node-title" x="0" y="15" text-anchor="middle">output?</text>
        </g>
        <text class="pf-note amber" x="600" y="375" text-anchor="middle">checking rule</text>

        <g class="pf-node done-node" transform="translate(770, 265)">
          <rect x="0" y="0" width="100" height="70" rx="35" />
          <text class="pf-node-title" x="50" y="40" text-anchor="middle">Done</text>
        </g>
      </>
    )}

    {pattern.slug === "plan-execute-verify" && (
      <>
        <g class="pf-lines" stroke-width="2" fill="none">
          <path class="pf-track" d="M 165 300 L 240 300" marker-end={markerUrl.muted} />
          <path class="pf-pulse muted" d="M 165 300 L 235 300" />
          <path class="pf-track" d="M 395 300 L 490 300" marker-end={markerUrl.muted} />
          <path class="pf-pulse muted" d="M 395 300 L 485 300" />
          <path class="pf-track yes" d="M 645 300 L 740 300" marker-end={markerUrl.yes} />
          <path class="pf-pulse yes" d="M 645 300 L 735 300" />
          <path class="pf-track loop" d="M 540 345 C 540 450, 350 450, 350 355" marker-end={markerUrl.loop} />
          <path class="pf-pulse loop" d="M 540 345 C 540 450, 350 450, 350 355" />
        </g>
        <text class="pf-label" x="442" y="290" text-anchor="middle">plan</text>
        <text class="pf-label yes" x="692" y="290" text-anchor="middle">valid</text>
        <text class="pf-label loop" x="445" y="465" text-anchor="middle">feedback / revise</text>

        <g class="pf-node start-node" transform="translate(140, 300)">
          <circle cx="0" cy="0" r="20" />
        </g>
        <text class="pf-note" x="140" y="340" text-anchor="middle">Start</text>

        <g class="pf-node model-node" transform="translate(250, 260)">
          <rect x="0" y="0" width="140" height="80" rx="10" />
          <text class="pf-node-title" x="70" y="45" text-anchor="middle">Plan</text>
        </g>
        <text class="pf-note" x="320" y="365" text-anchor="middle">generate</text>

        <g class="pf-node model-node" transform="translate(500, 260)">
          <rect x="0" y="0" width="140" height="80" rx="10" />
          <text class="pf-node-title" x="70" y="45" text-anchor="middle">Checker</text>
        </g>
        <text class="pf-note" x="570" y="365" text-anchor="middle">check</text>

        <g class="pf-node done-node" transform="translate(750, 265)">
          <rect x="0" y="0" width="100" height="70" rx="35" />
          <text class="pf-node-title" x="50" y="40" text-anchor="middle">Done</text>
        </g>
      </>
    )}

    {pattern.slug === "explore-narrow" && (
      <>
        <g class="pf-lines" stroke-width="2" fill="none">
          <path class="pf-track" d="M 180 300 L 270 300" marker-end={markerUrl.muted} />
          <path class="pf-pulse muted" d="M 180 300 L 265 300" />
          <path class="pf-track loop" d="M 410 300 C 470 300, 470 210, 530 210" marker-end={markerUrl.loop} />
          <path class="pf-pulse loop" d="M 410 300 C 470 300, 470 210, 525 210" />
          <path class="pf-track yes" d="M 410 300 C 470 300, 470 390, 530 390" marker-end={markerUrl.yes} />
          <path class="pf-pulse yes" d="M 410 300 C 470 300, 470 390, 525 390" />
        </g>

        <g class="pf-node start-node" transform="translate(140, 300)">
          <circle cx="0" cy="0" r="20" />
        </g>
        <text class="pf-note" x="140" y="340" text-anchor="middle">Start</text>

        <g class="pf-node model-node" transform="translate(280, 260)">
          <rect x="0" y="0" width="130" height="80" rx="10" />
          <text class="pf-node-title" x="65" y="45" text-anchor="middle">Model</text>
        </g>
        <text class="pf-note" x="345" y="365" text-anchor="middle">make options</text>

        <g class="pf-node path-a-node" transform="translate(540, 175)">
          <rect x="0" y="0" width="120" height="70" rx="10" />
          <text class="pf-node-title" x="60" y="40" text-anchor="middle">Path A</text>
        </g>

        <g class="pf-node path-b-node" transform="translate(540, 355)">
          <rect x="0" y="0" width="120" height="70" rx="10" />
          <text class="pf-node-title" x="60" y="40" text-anchor="middle">Path B</text>
        </g>
      </>
    )}

    {pattern.slug === "human-in-the-loop" && (
      <>
        <g class="pf-lines" stroke-width="2" fill="none">
          <path class="pf-track" d="M 180 300 L 270 300" marker-end={markerUrl.muted} />
          <path class="pf-pulse muted" d="M 180 300 L 265 300" />
          <path class="pf-track" d="M 410 300 L 520 300" marker-end={markerUrl.muted} />
          <path class="pf-pulse muted" d="M 410 300 L 515 300" />
          <path class="pf-track loop" d="M 660 300 L 760 300" marker-end={markerUrl.loop} />
          <path class="pf-pulse loop" d="M 660 300 L 755 300" />
        </g>

        <g class="pf-node start-node" transform="translate(140, 300)">
          <circle cx="0" cy="0" r="20" />
        </g>
        <text class="pf-note" x="140" y="340" text-anchor="middle">Start</text>

        <g class="pf-node model-node" transform="translate(280, 260)">
          <rect x="0" y="0" width="130" height="80" rx="10" />
          <text class="pf-node-title" x="65" y="45" text-anchor="middle">Model</text>
        </g>

        <g class="pf-node human-gate-node" transform="translate(590, 300)">
          <polygon points="0,-60 60,0 0,60 -60,0" />
          <text class="pf-node-title" x="0" y="-5" text-anchor="middle">Ask</text>
          <text class="pf-node-title" x="0" y="15" text-anchor="middle">person</text>
        </g>

        <g class="pf-node blue-done-node" transform="translate(770, 265)">
          <rect x="0" y="0" width="100" height="70" rx="35" />
          <text class="pf-node-title" x="50" y="40" text-anchor="middle">Done</text>
        </g>
      </>
    )}

    {pattern.slug === "verification" && (
      <>
        <g class="pf-lines" stroke-width="2" fill="none">
          <path class="pf-track" d="M 300 300 L 385 300" marker-end={markerUrl.muted} />
          <path class="pf-pulse muted" d="M 300 300 L 380 300" />
          <path class="pf-track" d="M 500 300 L 565 300" marker-end={markerUrl.muted} />
          <path class="pf-pulse muted" d="M 500 300 L 560 300" />
          <path class="pf-track yes" d="M 690 300 L 765 300" marker-end={markerUrl.yes} />
          <path class="pf-pulse yes" d="M 690 300 L 760 300" />
          <path class="pf-track loop" d="M 620 245 C 600 125, 225 125, 225 250" marker-end={markerUrl.loop} />
          <path class="pf-pulse loop" d="M 620 245 C 600 125, 225 125, 225 245" />
        </g>
        <text class="pf-label loop" x="420" y="125" text-anchor="middle">feedback: not good yet</text>
        <text class="pf-label yes" x="730" y="290" text-anchor="middle">pass</text>

        <g class="pf-node model-node" transform="translate(160, 260)">
          <rect x="0" y="0" width="140" height="80" rx="10" />
          <text class="pf-node-title" x="70" y="45" text-anchor="middle">Worker</text>
        </g>
        <text class="pf-note" x="230" y="360" text-anchor="middle">produce output</text>

        <g class="pf-node eval-node" transform="translate(390, 250)">
          <rect x="0" y="0" width="110" height="100" rx="10" />
          <path class="pf-checkmark" d="M31 55 l16 16 l34 -42" />
          <text class="pf-node-title" x="55" y="88" text-anchor="middle">Checklist</text>
        </g>
        <text class="pf-note" x="445" y="375" text-anchor="middle">checker</text>

        <g class="pf-node decision-node" transform="translate(625, 300)">
          <polygon points="0,-50 65,0 0,50 -65,0" />
          <text class="pf-node-title" x="0" y="-5" text-anchor="middle">good</text>
          <text class="pf-node-title" x="0" y="15" text-anchor="middle">enough?</text>
        </g>

        <g class="pf-node done-node" transform="translate(770, 265)">
          <rect x="0" y="0" width="100" height="70" rx="35" />
          <text class="pf-node-title" x="50" y="40" text-anchor="middle">Ship</text>
        </g>
      </>
    )}

    {pattern.slug === "event-driven" && (
      <>
        <g class="pf-lines" stroke-width="2" fill="none">
          <path class="pf-track" d="M 180 300 L 270 300" marker-end={markerUrl.muted} />
          <path class="pf-pulse muted" d="M 180 300 L 265 300" />
          <path class="pf-track" d="M 410 300 L 465 300" marker-end={markerUrl.muted} />
          <path class="pf-pulse muted" d="M 410 300 L 460 300" />
          <path class="pf-track" d="M 600 300 L 665 300" marker-end={markerUrl.muted} />
          <path class="pf-pulse muted" d="M 600 300 L 660 300" />
          <path class="pf-track yes" d="M 790 300 L 850 300" marker-end={markerUrl.yes} />
          <path class="pf-pulse yes" d="M 790 300 L 845 300" />
          <path class="pf-track loop" d="M 880 260 C 900 120, 150 120, 150 255" marker-end={markerUrl.loop} />
          <path class="pf-pulse loop" d="M 880 260 C 900 120, 150 120, 150 250" />
        </g>
        <text class="pf-label loop" x="510" y="120" text-anchor="middle">next event</text>
        <text class="pf-label yes" x="822" y="290" text-anchor="middle">wait</text>

        <g class="pf-node event-node" transform="translate(150, 300)">
          <circle cx="0" cy="0" r="30" />
          <path d="M-12 -4 h24 M0 -16 v32 M-10 -12 l20 20 M10 -12 -10 12" />
        </g>
        <text class="pf-note" x="150" y="355" text-anchor="middle">new item / schedule</text>

        <g class="pf-node plan-node" transform="translate(275, 260)">
          <rect x="0" y="0" width="135" height="80" rx="10" />
          <text class="pf-node-title" x="67" y="45" text-anchor="middle">Queue</text>
        </g>

        <g class="pf-node model-node" transform="translate(465, 260)">
          <rect x="0" y="0" width="135" height="80" rx="10" />
          <text class="pf-node-title" x="67" y="45" text-anchor="middle">Agent</text>
        </g>
        <text class="pf-note" x="532" y="360" text-anchor="middle">do the work</text>

        <g class="pf-node tools-node" transform="translate(665, 260)">
          <rect x="0" y="0" width="125" height="80" rx="10" />
          <text class="pf-node-title" x="62" y="45" text-anchor="middle">Update</text>
        </g>
        <text class="pf-note" x="727" y="360" text-anchor="middle">save result</text>

        <g class="pf-node done-node" transform="translate(850, 265)">
          <rect x="0" y="0" width="95" height="70" rx="35" />
          <text class="pf-node-title" x="48" y="40" text-anchor="middle">Idle</text>
        </g>
      </>
    )}

    {pattern.slug === "hill-climbing" && (
      <>
        <g class="pf-lines" stroke-width="2" fill="none">
          <path class="pf-track" d="M 240 300 L 305 300" marker-end={markerUrl.muted} />
          <path class="pf-pulse muted" d="M 240 300 L 300 300" />
          <path class="pf-track" d="M 455 300 L 520 300" marker-end={markerUrl.muted} />
          <path class="pf-pulse muted" d="M 455 300 L 515 300" />
          <path class="pf-track yes" d="M 645 300 L 700 300" marker-end={markerUrl.yes} />
          <path class="pf-pulse yes" d="M 645 300 L 695 300" />
          <path class="pf-track" d="M 820 300 L 850 300" marker-end={markerUrl.muted} />
          <path class="pf-pulse muted" d="M 820 300 L 845 300" />
          <path class="pf-track loop" d="M 890 260 C 890 125, 165 125, 165 250" marker-end={markerUrl.loop} />
          <path class="pf-pulse loop" d="M 890 260 C 890 125, 165 125, 165 245" />
        </g>
        <text class="pf-label loop" x="520" y="125" text-anchor="middle">past runs improve the setup</text>
        <path class="pf-metric-line" d="M 118 420 C 180 415, 230 392, 282 360 C 336 326, 390 302, 455 284" />
        <text class="pf-label yes" x="675" y="290" text-anchor="middle">review</text>

        <g class="pf-node trace-node" transform="translate(120, 250)">
          <rect x="0" y="0" width="120" height="80" rx="10" />
          <path class="pf-doc-line" d="M24 275 h72 M24 294 h60 M24 313 h78" transform="translate(0,-250)" />
          <text class="pf-node-title" x="60" y="47" text-anchor="middle">History</text>
        </g>
        <text class="pf-note" x="180" y="350" text-anchor="middle">past runs</text>

        <g class="pf-node model-node" transform="translate(310, 260)">
          <rect x="0" y="0" width="145" height="80" rx="10" />
          <text class="pf-node-title" x="72" y="45" text-anchor="middle">Analyze</text>
        </g>

        <g class="pf-node decision-node" transform="translate(585, 300)">
          <polygon points="0,-50 65,0 0,50 -65,0" />
          <text class="pf-node-title" x="0" y="-5" text-anchor="middle">better</text>
          <text class="pf-node-title" x="0" y="15" text-anchor="middle">setup?</text>
        </g>

        <g class="pf-node tools-node" transform="translate(700, 260)">
          <rect x="0" y="0" width="120" height="80" rx="10" />
          <text class="pf-node-title" x="60" y="45" text-anchor="middle">Update</text>
        </g>
        <text class="pf-note" x="760" y="360" text-anchor="middle">saved change</text>

        <g class="pf-node done-node" transform="translate(850, 265)">
          <rect x="0" y="0" width="110" height="70" rx="35" />
          <text class="pf-node-title" x="55" y="40" text-anchor="middle">Measure</text>
        </g>
      </>
    )}
  </svg>
</div>
