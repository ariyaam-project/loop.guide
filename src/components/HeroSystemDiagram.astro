<div class="system-visual hero-system-diagram" aria-label="Animated diagram showing how an AI loop uses results">
  <div class="loop-runtime">
    <svg
      class="hero-flow hero-flow-wide"
      viewBox="80 85 880 420"
      role="img"
      aria-label="An AI uses what it knows, tries something, checks the result, and repeats when the result matters."
    >
      <defs>
        <marker id="hero-arrow-muted" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="8" markerHeight="8" orient="auto">
          <path class="arrowhead arrowhead-muted" d="M 0 1 L 10 5 L 0 9 z" fill="var(--text-faint, #89919a)" />
        </marker>
        <marker id="hero-arrow-loop" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="8" markerHeight="8" orient="auto">
          <path class="arrowhead arrowhead-loop" d="M 0 1 L 10 5 L 0 9 z" fill="var(--accent, #2457d6)" />
        </marker>
        <marker id="hero-arrow-yes" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="8" markerHeight="8" orient="auto">
          <path class="arrowhead arrowhead-yes" d="M 0 1 L 10 5 L 0 9 z" fill="var(--green, #0f7d5d)" />
        </marker>
        <marker id="hero-arrow-no" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="8" markerHeight="8" orient="auto">
          <path class="arrowhead arrowhead-no" d="M 0 1 L 10 5 L 0 9 z" fill="var(--red, #bf3f37)" />
        </marker>
      </defs>

      <g class="flow-lines" stroke-width="2" fill="none">
        <path class="flow-track" d="M 255 250 L 320 250" stroke="var(--text-faint, #89919a)" opacity="0.34" marker-end="url(#hero-arrow-muted)" />
        <path class="flow-pulse muted" d="M 255 250 L 315 250" stroke="var(--text-dim, #5d6670)" stroke-width="2.4" stroke-linecap="round" stroke-dasharray="8 8" />

        <path class="flow-track" d="M 470 250 L 590 250" stroke="var(--text-faint, #89919a)" opacity="0.34" marker-end="url(#hero-arrow-muted)" />
        <path class="flow-pulse muted" d="M 470 250 L 585 250" stroke="var(--text-dim, #5d6670)" stroke-width="2.4" stroke-linecap="round" stroke-dasharray="8 8" />

        <path class="flow-track yes" d="M 720 250 L 780 250" stroke="var(--green, #0f7d5d)" opacity="0.48" marker-end="url(#hero-arrow-yes)" />
        <path class="flow-pulse yes" d="M 720 250 L 775 250" stroke="var(--green, #0f7d5d)" stroke-width="2.4" stroke-linecap="round" stroke-dasharray="8 8" />

        <path class="flow-track no" d="M 660 300 L 660 375" stroke="var(--red, #bf3f37)" opacity="0.48" marker-end="url(#hero-arrow-no)" />
        <path class="flow-pulse no" d="M 660 300 L 660 370" stroke="var(--red, #bf3f37)" stroke-width="2.4" stroke-linecap="round" stroke-dasharray="8 8" />

        <path class="flow-track loopback" d="M 855 205 L 855 130 L 180 130 L 180 195" stroke="var(--accent, #2457d6)" opacity="0.42" marker-end="url(#hero-arrow-loop)" />
        <path class="flow-pulse loopback" d="M 855 205 L 855 130 L 180 130 L 180 190" stroke="var(--accent, #2457d6)" stroke-width="2.4" stroke-linecap="round" stroke-dasharray="10 10" />
      </g>

      <text class="flow-label label-yes" x="750" y="240" text-anchor="middle" fill="var(--green, #0f7d5d)">yes</text>
      <text class="flow-label label-no" x="675" y="340" text-anchor="start" fill="var(--red, #bf3f37)">no</text>
      <text class="flow-caption" x="517" y="115" text-anchor="middle" fill="var(--accent-strong, #173f9d)">new result  ->  try again</text>

      <g class="flow-node context-node" transform="translate(180, 250)">
        <ellipse cx="0" cy="0" rx="75" ry="45" fill="var(--v-single-bg, #dfe8ff)" stroke="var(--accent, #2457d6)" stroke-width="2" />
        <text class="node-title" x="0" y="5" text-anchor="middle" fill="var(--text, #171b21)">What it knows</text>
      </g>
      <text class="node-note" x="180" y="315" text-anchor="middle" fill="var(--text-dim, #5d6670)">goal and latest result</text>

      <g class="flow-node model-node" transform="translate(330, 205)">
        <rect x="0" y="0" width="140" height="90" rx="10" fill="var(--v-chain-bg, #f0e6ff)" stroke="var(--v-chain-ink, #6840a0)" stroke-width="2" />
        <text class="node-title" x="70" y="50" text-anchor="middle" fill="var(--text, #171b21)">AI</text>
      </g>
      <text class="node-note" x="400" y="315" text-anchor="middle" fill="var(--text-dim, #5d6670)">choose next step</text>

      <g class="flow-node decision-node" transform="translate(660, 250)">
        <polygon points="0,-50 60,0 0,50 -60,0" fill="var(--amber-soft, #f7e7c7)" stroke="var(--amber, #b66b00)" stroke-width="2" />
        <text class="node-title" x="0" y="-5" text-anchor="middle" fill="var(--v-border-ink, #875100)">need</text>
        <text class="node-title" x="0" y="15" text-anchor="middle" fill="var(--v-border-ink, #875100)">a check?</text>
      </g>

      <g class="flow-node tools-node" transform="translate(790, 205)">
        <rect x="0" y="0" width="130" height="90" rx="10" fill="var(--accent, #2457d6)" stroke="var(--accent-strong, #173f9d)" stroke-width="2" />
        <text class="node-title" x="65" y="50" text-anchor="middle" fill="var(--paper, #fffefa)">Check</text>
      </g>
      <text class="node-note" x="855" y="315" text-anchor="middle" fill="var(--text-dim, #5d6670)">tests, files, replies</text>

      <g class="flow-node end-node" transform="translate(660, 420)">
        <ellipse cx="0" cy="0" rx="50" ry="35" fill="var(--red-soft, #fae4e1)" stroke="var(--red, #bf3f37)" stroke-width="2" />
        <text class="node-title" x="0" y="5" text-anchor="middle" fill="var(--text, #171b21)">Stop</text>
      </g>
      <text class="node-note no-note" x="660" y="475" text-anchor="middle" fill="var(--red, #bf3f37)">stop when there is nothing useful to observe</text>
    </svg>

    <svg class="hero-flow hero-flow-compact" viewBox="0 0 360 470" aria-hidden="true">
      <defs>
        <marker id="hero-compact-arrow-muted" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="8" markerHeight="8" orient="auto">
          <path class="arrowhead arrowhead-muted" d="M 0 1 L 10 5 L 0 9 z" fill="var(--text-faint, #89919a)" />
        </marker>
        <marker id="hero-compact-arrow-loop" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="8" markerHeight="8" orient="auto">
          <path class="arrowhead arrowhead-loop" d="M 0 1 L 10 5 L 0 9 z" fill="var(--accent, #2457d6)" />
        </marker>
        <marker id="hero-compact-arrow-yes" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="8" markerHeight="8" orient="auto">
          <path class="arrowhead arrowhead-yes" d="M 0 1 L 10 5 L 0 9 z" fill="var(--green, #0f7d5d)" />
        </marker>
        <marker id="hero-compact-arrow-no" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="8" markerHeight="8" orient="auto">
          <path class="arrowhead arrowhead-no" d="M 0 1 L 10 5 L 0 9 z" fill="var(--red, #bf3f37)" />
        </marker>
      </defs>

      <g class="flow-lines" stroke-width="2" fill="none">
        <path class="flow-track" d="M 105 102 L 105 145" stroke="var(--text-faint, #89919a)" opacity="0.34" marker-end="url(#hero-compact-arrow-muted)" />
        <path class="flow-pulse muted" d="M 105 102 L 105 140" stroke="var(--text-dim, #5d6670)" stroke-width="2.4" stroke-linecap="round" stroke-dasharray="8 8" />

        <path class="flow-track" d="M 105 220 L 105 245" stroke="var(--text-faint, #89919a)" opacity="0.34" marker-end="url(#hero-compact-arrow-muted)" />
        <path class="flow-pulse muted" d="M 105 220 L 105 240" stroke="var(--text-dim, #5d6670)" stroke-width="2.4" stroke-linecap="round" stroke-dasharray="8 8" />

        <path class="flow-track yes" d="M 157 292 L 215 292" stroke="var(--green, #0f7d5d)" opacity="0.48" marker-end="url(#hero-compact-arrow-yes)" />
        <path class="flow-pulse yes" d="M 157 292 L 210 292" stroke="var(--green, #0f7d5d)" stroke-width="2.4" stroke-linecap="round" stroke-dasharray="8 8" />

        <path class="flow-track no" d="M 105 337 L 105 372" stroke="var(--red, #bf3f37)" opacity="0.48" marker-end="url(#hero-compact-arrow-no)" />
        <path class="flow-pulse no" d="M 105 337 L 105 367" stroke="var(--red, #bf3f37)" stroke-width="2.4" stroke-linecap="round" stroke-dasharray="8 8" />

        <path class="flow-track loopback" d="M 275 248 L 275 28 L 105 28 L 105 32" stroke="var(--accent, #2457d6)" opacity="0.42" marker-end="url(#hero-compact-arrow-loop)" />
        <path class="flow-pulse loopback" d="M 275 248 L 275 28 L 105 28 L 105 32" stroke="var(--accent, #2457d6)" stroke-width="2.4" stroke-linecap="round" stroke-dasharray="10 10" />
      </g>

      <text class="flow-caption" x="198" y="20" text-anchor="middle" fill="var(--accent-strong, #173f9d)">new result -> repeat</text>
      <text class="flow-label label-yes" x="184" y="281" text-anchor="middle" fill="var(--green, #0f7d5d)">yes</text>
      <text class="flow-label label-no" x="128" y="363" text-anchor="start" fill="var(--red, #bf3f37)">no</text>

      <g class="flow-node context-node" transform="translate(105, 68)">
        <ellipse cx="0" cy="0" rx="68" ry="34" fill="var(--v-single-bg, #dfe8ff)" stroke="var(--accent, #2457d6)" stroke-width="2" />
        <text class="node-title" x="0" y="5" text-anchor="middle" fill="var(--text, #171b21)">Knows</text>
      </g>

      <g class="flow-node model-node" transform="translate(40, 150)">
        <rect x="0" y="0" width="130" height="70" rx="10" fill="var(--v-chain-bg, #f0e6ff)" stroke="var(--v-chain-ink, #6840a0)" stroke-width="2" />
        <text class="node-title" x="65" y="42" text-anchor="middle" fill="var(--text, #171b21)">AI</text>
      </g>

      <g class="flow-node decision-node" transform="translate(105, 292)">
        <polygon points="0,-45 52,0 0,45 -52,0" fill="var(--amber-soft, #f7e7c7)" stroke="var(--amber, #b66b00)" stroke-width="2" />
        <text class="node-title" x="0" y="-5" text-anchor="middle" fill="var(--v-border-ink, #875100)">need</text>
        <text class="node-title" x="0" y="14" text-anchor="middle" fill="var(--v-border-ink, #875100)">check?</text>
      </g>

      <g class="flow-node tools-node" transform="translate(220, 248)">
        <rect x="0" y="0" width="110" height="74" rx="10" fill="var(--accent, #2457d6)" stroke="var(--accent-strong, #173f9d)" stroke-width="2" />
        <text class="node-title" x="55" y="44" text-anchor="middle" fill="var(--paper, #fffefa)">Check</text>
      </g>
      <text class="node-note" x="275" y="342" text-anchor="middle" fill="var(--text-dim, #5d6670)">new result</text>

      <g class="flow-node end-node" transform="translate(105, 410)">
        <ellipse cx="0" cy="0" rx="52" ry="32" fill="var(--red-soft, #fae4e1)" stroke="var(--red, #bf3f37)" stroke-width="2" />
        <text class="node-title" x="0" y="5" text-anchor="middle" fill="var(--text, #171b21)">Stop</text>
      </g>
      <text class="node-note no-note" x="105" y="458" text-anchor="middle" fill="var(--red, #bf3f37)">no useful signal</text>
    </svg>
  </div>
</div>
